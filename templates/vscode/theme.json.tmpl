    {
      "scope": "markup.inline.raw",
      "settings": { "foreground": "{{.Green}}" }
    },
    {
      "scope": "markup.fenced_code",
      "settings": { "foreground": "{{.Green}}" }
    },
    {
      "scope": "invalid",
      "settings": { "foreground": "{{.Red}}" }
    }
