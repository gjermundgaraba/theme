@charset "UTF-8";
/* CSS Document */

/** code highlight */

.cm-s-inner .cm-variable {
    color: {{.Green}}
}

.cm-s-inner .cm-operator {
    color: {{.Magenta}}
}

.cm-s-inner .cm-property {
    color: {{.FG}};
}

.cm-s-inner .cm-keyword {
    color: {{.Magenta}};
}

.cm-s-inner .cm-tag {
    color: {{.Magenta}};
}

.cm-s-inner .cm-attribute {
    color: {{.Green}};
}

.CodeMirror div.CodeMirror-cursor {
    border-left: 1px solid {{.FG}};
    z-index: 3;
}

.cm-s-inner .cm-string,
.cm-s-inner .cm-string-2 {
    color: {{.Yellow}};
}

.cm-s-inner .cm-comment,
.cm-s-inner.cm-comment {
    color: {{.FGDim}};
}

.cm-s-inner .cm-header,
.cm-s-inner.cm-header,
.cm-s-inner .cm-def,
.cm-s-inner.cm-def {
    color: {{.Cyan}};
}

.cm-s-inner .cm-quote,
.cm-s-inner.cm-quote {
    color: {{.Green}};
}

.cm-s-inner .cm-hr {
    color: {{.FGDim}};
}

.cm-s-inner .cm-link {
    color: {{.BrightBlue}};
}

.cm-s-inner .cm-negative {
    color: {{.Red}};
}

.cm-s-inner .cm-positive {
    color: {{.Green}};
}

.cm-s-inner .cm-meta,
.cm-s-inner .cm-qualifier {
    color: {{.Green}};
}

.cm-s-inner .cm-builtin {
    color: {{.Green}};
}

.cm-s-inner .cm-bracket {
    color: {{.FG}};
}

.cm-s-inner .cm-atom,
.cm-s-inner.cm-atom {
    color: {{.Cyan}};
}

.cm-s-inner .cm-number {
    color: {{.Blue}};
}

.cm-s-inner .cm-variable {
    color: {{.FG}};
}

.cm-s-inner .cm-variable-2 {
    color: {{.FG}};
}

.cm-s-inner .cm-variable-3 {
    color: {{.Cyan}};
    font-style: italic;
}

.CodeMirror-selectedtext,
.CodeMirror-selected {
    background: {{.Surface}};
    color: #fff !important;
    text-shadow: none;
}
