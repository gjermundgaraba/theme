@import "{{.Name}}/mermaid.dark.css";
@import "{{.Name}}/codeblock.dark.css";
@import "{{.Name}}/sourcemode.dark.css";

:root {
  --bg-color: {{.BG}};
  --side-bar-bg-color: {{.Surface}};
  --text-color: {{.FGDim}};

  --select-text-bg-color: {{.Surface}};

  --item-hover-bg-color: {{.Surface}};
  --control-text-color: {{.FG}};
  --control-text-hover-color: {{.Cyan}};
  --window-border: 1px dashed {{.BG}};

  --active-file-bg-color: {{.BG}};
  --active-file-border-color: {{.Surface}};

  --primary-color: {{.Cyan}};

  --active-file-text-color: white;
  --item-hover-bg-color: {{.Overlay}};
  --item-hover-text-color: white;
  --primary-color: {{.Cyan}};
  /* implicit mathjax edit panel background color */
  --rawblock-edit-panel-bd: #151320;
  --monospace: "Berkeley Mono", ui-monospace, monospace;
}

/* Space Grotesk — headings */
@font-face {
  font-family: "Space Grotesk";
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url("./{{.Name}}/space-grotesk-v22-latin-regular.woff2") format("woff2");
}
@font-face {
  font-family: "Space Grotesk";
  font-style: normal;
  font-weight: 600;
  font-display: swap;
  src: url("./{{.Name}}/space-grotesk-v22-latin-600.woff2") format("woff2");
}
@font-face {
  font-family: "Space Grotesk";
  font-style: normal;
  font-weight: 700;
  font-display: swap;
  src: url("./{{.Name}}/space-grotesk-v22-latin-700.woff2") format("woff2");
}

/* Satoshi — body text */
@font-face {
  font-family: "Satoshi";
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url("./{{.Name}}/satoshi-regular.woff2") format("woff2");
}
@font-face {
  font-family: "Satoshi";
  font-style: normal;
  font-weight: 500;
  font-display: swap;
  src: url("./{{.Name}}/satoshi-medium.woff2") format("woff2");
}
@font-face {
  font-family: "Satoshi";
  font-style: normal;
  font-weight: 700;
  font-display: swap;
  src: url("./{{.Name}}/satoshi-bold.woff2") format("woff2");
}

/* Berkeley Mono — code */
@font-face {
  font-family: "Berkeley Mono";
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url("./{{.Name}}/BerkeleyMono-Regular.woff2") format("woff2");
}
@font-face {
  font-family: "Berkeley Mono";
  font-style: normal;
  font-weight: 500;
  font-display: swap;
  src: url("./{{.Name}}/BerkeleyMono-Retina.woff2") format("woff2");
}
@font-face {
  font-family: "Berkeley Mono";
  font-style: normal;
  font-weight: 600;
  font-display: swap;
  src: url("./{{.Name}}/BerkeleyMono-Bold.woff2") format("woff2");
}

html {
  font-size: 16px;
}

html,
body {
  -webkit-text-size-adjust: 100%;
  -ms-text-size-adjust: 100%;
  background: {{.BG}};
  background: var(--bg-color);
  fill: currentColor;
}

#write {
  max-width: 914px;
  padding-top: 20px;
}

html,
body,
button,
input,
select,
textarea,
div.code-tooltip-content {
  color: {{.FG}};
}

div.code-tooltip,
.md-hover-tip .md-arrow:after {
  background: {{.Surface}};
}

.popover.bottom > .arrow:after {
  border-bottom-color: {{.Surface}};
}

html,
body,
button,
input,
select,
textarea {
  font-style: normal;
  line-height: 1.625rem;
  font-family: "Satoshi", system-ui, sans-serif;
}

hr {
  height: 2px;
  border: 0;
  margin: 24px 0 !important;
}

h1,
h2,
h3,
h4,
h5,
h6 {
  font-family: "Space Grotesk", system-ui, sans-serif;
  font-weight: normal;
  clear: both;
  -ms-word-wrap: break-word;
  word-wrap: break-word;
  margin: 0;
  padding: 0;
  color: {{.FG}};
}

h1 {
  font-size: 2.5rem;
  /* 36px */
  line-height: 2.75rem;
  /* 40px */
  margin-bottom: 1.5rem;
  /* 24px */
  letter-spacing: -1.5px;
}

h2 {
  font-size: 1.63rem;
  /* 24px */
  line-height: 1.875rem;
  /* 30px */
  margin-bottom: 1.5rem;
  /* 24px */
  letter-spacing: -1px;
  font-weight: bold;
}

h3 {
  font-size: 1.17rem;
  /* 18px */
  line-height: 1.5rem;
  /* 24px */
  margin-bottom: 1.5rem;
  /* 24px */
  letter-spacing: -1px;
  font-weight: bold;
}

h4 {
  font-size: 1.12rem;
  /* 16px */
  line-height: 1.375rem;
  /* 22px */
  margin-bottom: 1.5rem;
  /* 24px */
  color: white;
}

h5 {
  font-size: 0.97rem;
  /* 16px */
  line-height: 1.25rem;
  /* 22px */
  margin-bottom: 1.5rem;
  /* 24px */
  font-weight: bold;
}

h6 {
  font-size: 0.93rem;
  /* 16px */
  line-height: 1rem;
  /* 16px */
  margin-bottom: 0.75rem;
  color: white;
}

@media (min-width: 980px) {
  h3.md-focus:before,
  h4.md-focus:before,
  h5.md-focus:before,
  h6.md-focus:before {
    color: #ddd;
    border: 1px solid #ddd;
    border-radius: 3px;
    position: absolute;
    left: -1.642857143rem;
    top: 0.357142857rem;
    float: left;
    font-size: 9px;
    padding-left: 2px;
    padding-right: 2px;
    vertical-align: bottom;
    font-weight: normal;
    line-height: normal;
  }

  h3.md-focus:before {
    content: "h3";
  }

  h4.md-focus:before {
    content: "h4";
  }

  h5.md-focus:before {
    content: "h5";
    top: 0px;
  }

  h6.md-focus:before {
    content: "h6";
    top: 0px;
  }
}

a {
  text-decoration: none;
  outline: 0;
}

a:hover {
  outline: 0;
}

a:focus {
  outline: thin dotted;
}

sup.md-footnote {
  background-color: {{.Surface}};
  color: {{.FG}};
}

p {
  -ms-word-wrap: break-word;
  word-wrap: break-word;
}

p,
ul,
dd,
ol,
hr,
address,
pre,
table,
iframe,
.wp-caption,
.wp-audio-shortcode,
.wp-video-shortcode {
  margin-top: 0;
  margin-bottom: 1.5rem;
  /* 24px */
}

audio:not([controls]) {
  display: none;
}

[hidden] {
  display: none;
}

::-moz-selection {
  background: {{.SelectionBG}};
  color: {{.SelectionFG}};
  text-shadow: none;
}

*.in-text-selection,
::selection {
  background: {{.SelectionBG}};
  color: {{.SelectionFG}};
  text-shadow: none;
}

ul,
ol {
  padding: 0 0 0 1.875rem;
  /* 30px */
}

ul {
  list-style: square;
}

ol {
  list-style: decimal;
}

ul ul,
ol ol,
ul ol,
ol ul {
  margin: 0;
}

b,
th,
dt,
strong {
  font-weight: bold;
}

i,
em,
dfn,
cite {
  font-style: italic;
}

blockquote {
  padding-left: 1.875rem;
  margin: 0 0 1.875rem 1.875rem;
  border-left: solid 2px {{.Overlay}};
  padding-left: 30px;
  margin-top: 35px;
}

pre,
code,
kbd,
tt,
var {
  background: rgba(0, 0, 0, 0.05);
  font-size: 0.875rem;
  font-family: "Berkeley Mono", ui-monospace, monospace;
  border-radius: 5px;
  background: {{.Surface}};
}

pre.md-fences {
  padding: 10px 30px;
  margin-bottom: 20px;
  border: 1px solid;
  border-radius: 5px;
  background: {{.Surface}};
}

.md-fences .code-tooltip {
  bottom: -3.2em;
}

code,
kbd,
tt,
var {
  padding: 2px 5px;
}

kbd {
  color: #fff;
  box-shadow: inset 0 -1px 0 rgba(0,0,0,.25);
  font-size: 90%;
}

table {
  max-width: 100%;
  width: 100%;
  border-collapse: collapse;
  border-spacing: 0;
}

th,
td {
  padding: 5px 10px;
  vertical-align: top;
}

a {
  -webkit-transition: all 0.2s ease-in-out;
  transition: all 0.2s ease-in-out;
}

hr {
  background: {{.Overlay}};
}

#write > *:first-child {
  margin-top: 40px;
}

h1 {
  margin-top: 2em;
}

a {
  color: {{.Cyan}};
  text-decoration: underline;
}

a:hover {
  color: {{.BrightCyan}};
}

.md-inline-math script {
  color: {{.Blue}};
}

b,
th,
dt,
strong {
  color: {{.FG}};
}

mark {
  background: {{.Yellow}};
}

blockquote {
  color: {{.FGDim}};
}

table a {
  color: {{.FG}};
}

th,
td {
  border: solid 1px {{.Overlay}};
}

.task-list {
  padding-left: 0;
}

.md-task-list-item {
  padding-left: 1.25rem;
}

.md-task-list-item > input {
  top: auto;
}

.md-task-list-item > input:before {
  content: "";
  display: inline-block;
  width: 0.875rem;
  height: 0.875rem;
  vertical-align: middle;
  text-align: center;
  border: 1px solid {{.FGDim}};
  background-color: {{.BG}};
  margin-top: -0.4rem;
}

.md-task-list-item > input:checked:before,
.md-task-list-item > input[checked]:before {
  content: "\221A";
  font-size: 0.625rem;
  line-height: 0.625rem;
  color: {{.FG}};
}

.CodeMirror-gutters {
  background: transparent;
  border-right: 1px solid transparent;
}

/** quick open **/
.auto-suggest-container {
  border: 0px;
  background-color: {{.Surface}};
}

#typora-quick-open {
  background-color: {{.Surface}};
}

#typora-quick-open input {
  background-color: {{.Surface}};
  border: 0;
  border-bottom: 1px solid grey;
}

.typora-quick-open-item {
  background-color: inherit;
  color: inherit;
}

.typora-quick-open-item.active {
  background-color: {{.Blue}};
  color: white;
}

.typora-search-spinner > div {
  background-color: #fff;
}

#write pre.md-meta-block {
  border-bottom: 1px dashed #ccc;
  background: transparent;
  padding-bottom: 0.6em;
  line-height: 1.6em;
}

.btn,
.btn .btn-default {
  background: transparent;
  color: {{.FG}};
}

.ty-table-edit {
  border-top: 1px solid gray;
  background-color: {{.BG}};
}

.popover-title {
  background: transparent;
}

.md-image > .md-meta {
  color: {{.FGDim}};
  background: transparent;
}

.md-expand.md-image > .md-meta {
  color: {{.FG}};
}

#write > h3:before,
#write > h4:before,
#write > h5:before,
#write > h6:before {
  border: none;
  border-radius: 0px;
  color: {{.FGDim}};
  text-decoration: underline;
  left: -1.4rem;
  top: 0.2rem;
}

#write > h3.md-focus:before {
  top: 2px;
}

#write > h4.md-focus:before {
  top: 2px;
}

.md-toc-item {
  color: {{.Cyan}};
}

#write div.md-toc-tooltip {
  background-color: {{.BG}};
}

.dropdown-menu .btn:hover,
.dropdown-menu .btn:focus,
.md-toc .btn:hover,
.md-toc .btn:focus {
  color: white;
  background: black;
}

#toc-dropmenu {
  background: rgba(from {{.BG}} r g b / 0.93);
  border: 1px solid rgba(253, 253, 253, 0.15);
}

#toc-dropmenu .divider {
  background-color: {{.Overlay}};
}

.outline-expander:before {
  top: 2px;
}

#typora-sidebar {
  box-shadow: none;
  border-right: 1px dashed;
  border-right: none;
}

.sidebar-tabs {
  border-bottom: 0;
}

#typora-sidebar:hover .outline-title-wrapper {
  border-left: 1px dashed;
}

.outline-title-wrapper .btn {
  color: inherit;
}

.outline-item:hover {
  border-color: {{.BG}};
  background-color: {{.BG}};
  color: white;
}

h1.md-focus .md-attr,
h2.md-focus .md-attr,
h3.md-focus .md-attr,
h4.md-focus .md-attr,
h5.md-focus .md-attr,
h6.md-focus .md-attr,
.md-header-span .md-attr {
  color: {{.FGDim}};
  display: inline;
}

.md-comment {
  color: {{.Blue}};
  opacity: 1;
}

.md-inline-math g,
.md-inline-math svg {
  stroke: {{.FG}} !important;
  fill: {{.FG}} !important;
}

[md-inline="inline_math"] {
  color: {{.Blue}};
}

#math-inline-preview .md-arrow:after {
  background: black;
}

.modal-content {
  background: var(--bg-color);
  border: 0;
}

.modal-title {
  font-size: 1.5em;
}

.modal-content input {
  background-color: rgba(26, 21, 21, 0.51);
  color: white;
}

.modal-content .input-group-addon {
  background-color: rgba(0, 0, 0, 0.17);
  color: white;
}

.modal-backdrop {
  background-color: rgba(174, 174, 174, 0.7);
}

.modal-content .btn-primary {
  border-color: var(--primary-color);
}

.md-table-resize-popover {
  background-color: {{.Surface}};
}

.form-inline .input-group .input-group-addon {
  color: white;
}

#md-searchpanel {
  border-bottom: 1px dashed grey;
}

/** UI for electron */

.context-menu {
  background-color: {{.Surface}};
}

.context-menu.dropdown-menu .divider {
  background-color: {{.Overlay}};
}

footer {
  color: inherit;
}

@media (max-width: 1000px) {
  footer {
    border-top: none;
  }
  footer:hover {
    color: inherit;
  }
}

#file-info-file-path .file-info-field-value:hover {
  background-color: {{.Surface}};
  color: {{.FG}};
}

.megamenu-content,
.megamenu-opened header {
  background: var(--bg-color);
}

.megamenu-menu-panel h2,
.megamenu-menu-panel h1,
.long-btn {
  color: inherit;
}

.megamenu-menu-panel input[type="text"] {
  background: inherit;
  border: 0;
  border-bottom: 1px solid;
}

#recent-file-panel-action-btn {
  background: inherit;
  border: 1px grey solid;
}

.megamenu-menu-panel .btn:hover,
.megamenu-menu-panel .btn:focus,
.megamenu-menu-panel .btn.focus {
  color: white;
}

.megamenu-menu-panel .dropdown-menu > li > a {
  color: inherit;
  background-color: {{.BG}};
  text-decoration: none;
}

.megamenu-menu-panel table td:nth-child(1) {
  color: inherit;
  font-weight: bold;
}

.megamenu-menu-panel tbody tr:hover td:nth-child(1) {
  color: white;
}

.modal-footer .btn-default,
.modal-footer .btn-primary,
.modal-footer .btn-default:not(:hover) {
  border: 1px solid;
  border-color: transparent;
}

.btn-default:hover,
.btn-default:focus,
.btn-default.focus,
.btn-default:active,
.btn-default.active,
.open > .dropdown-toggle.btn-default {
  color: white;
  border: 1px solid #ddd;
  background-color: inherit;
}

.modal-header {
  border-bottom: 0;
}

.modal-footer {
  border-top: 0;
}

#recent-file-panel tbody tr:nth-child(2n-1) {
  background-color: transparent !important;
}

.megamenu-menu-panel tbody tr:hover td:nth-child(2) {
  color: inherit;
}

.megamenu-menu-panel .btn {
  border: 1px solid #eee;
  background: transparent;
}

.mouse-hover .toolbar-icon.btn:hover,
#w-full.mouse-hover,
#w-pin.mouse-hover {
  background-color: inherit;
}

.typora-node::-webkit-scrollbar {
  width: 5px;
}

.typora-node::-webkit-scrollbar-thumb:vertical {
  background: rgba(250, 250, 250, 0.3);
}

.typora-node::-webkit-scrollbar-thumb:vertical:active {
  background: rgba(250, 250, 250, 0.5);
}

#w-unpin {
  background-color: {{.Blue}};
}

#top-titlebar,
#top-titlebar * {
  color: var(--item-hover-text-color);
}

.typora-sourceview-on #toggle-sourceview-btn,
#footer-word-count:hover,
.show-word-count #footer-word-count {
  background: {{.BG}};
}

#toggle-sourceview-btn:hover {
  color: #eee;
  background: {{.BG}};
}

/** focus mode */
.on-focus-mode .md-end-block:not(.md-focus):not(.md-focus-container) * {
  color: {{.FGDim}} !important;
}

.on-focus-mode .md-end-block:not(.md-focus) img,
.on-focus-mode .md-task-list-item:not(.md-focus-container) > input {
  opacity: 0.4 !important;
}

.on-focus-mode li[cid]:not(.md-focus-container) {
  color: {{.FGDim}};
}

.on-focus-mode
  .md-fences.md-focus
  .CodeMirror-code
  > *:not(.CodeMirror-activeline)
  *,
.on-focus-mode .CodeMirror.cm-s-inner:not(.CodeMirror-focused) * {
  color: {{.FGDim}} !important;
}

.on-focus-mode .md-focus,
.on-focus-mode .md-focus-container {
  color: {{.FG}};
}

.on-focus-mode
  #typora-source
  .CodeMirror-code
  > *:not(.CodeMirror-activeline)
  * {
  color: {{.FGDim}} !important;
}

/*diagrams*/
#write .md-focus .md-diagram-panel {
  border: 1px solid #ddd;
  margin-left: -30px;
}

/*diagrams*/
#write.show-fences-line-number .md-focus .md-diagram-panel {
  margin-left: auto;
}

.md-diagram-panel-error {
  color: {{.Red}};
}

.active-tab-files #info-panel-tab-file,
.active-tab-files #info-panel-tab-file:hover,
.active-tab-outline #info-panel-tab-outline,
.active-tab-outline #info-panel-tab-outline:hover {
  color: #eee;
}

.sidebar-footer-item:hover,
.footer-item:hover {
  background: inherit;
  color: white;
}

.ty-side-sort-btn.active,
.ty-side-sort-btn:hover,
.selected-folder-menu-item a:after {
  color: white;
}

#sidebar-files-menu {
  border: solid 1px;
  box-shadow: 4px 4px 20px rgba(0, 0, 0, 0.79);
  background-color: var(--bg-color);
}

.file-list-item {
  border-bottom: none;
}

.file-list-item-summary {
  opacity: 1;
}

.file-list-item.active:first-child {
  border-top: none;
}

.sidebar-footer {
  border-top: 1px solid {{.Overlay}};
}

.file-node-background {
  height: 32px;
}

.file-library-node.active > .file-node-content,
.file-list-item.active {
  color: white;
  color: var(--active-file-text-color);
}

.file-library-node.active > .file-node-background {
  background-color: {{.BG}};
  background-color: var(--active-file-bg-color);
}
.file-list-item.active {
  background-color: {{.BG}};
  background-color: var(--active-file-bg-color);
}

#ty-tooltip {
  background-color: black;
  color: #eee;
}

#write {
  cursor: -webkit-image-set(
        url("{{.Name}}/cursor.png") 1x,
        url("{{.Name}}/cursor@2x.png") 2x
      )
      8 8,
    auto;
}

.md-task-list-item > input {
  margin-left: -1.3em;
  margin-top: calc(1rem - 10px);
  -webkit-appearance: none;
}
